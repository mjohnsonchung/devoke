# Copy this to .env.local and fill in your values.
# Never commit .env.local to git.

# Supabase — find in Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # secret, server-side only

PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=eyJ...    # safe to expose in client

# Stripe — find in Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...    # from: stripe listen --print-secret

# Stripe Price IDs — create these in Stripe dashboard → Products
STRIPE_PRICE_BASIC=price_...       # Basic tier monthly price
STRIPE_PRICE_PRO=price_...         # Pro tier monthly price

# Anthropic — platform.claude.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...
