---
// InstallCTA — bottom-of-page CTA section.
// Large editorial headline, single install button, quiet footnote.
---

<section class="cta section grain" id="install" aria-label="Install Devoke">
  <!-- Large ambient ◎ behind content -->
  <div class="cta__mark" aria-hidden="true">◎</div>

  <div class="container cta__inner">
    <h2 class="cta__heading reveal">
      The web you remember.<br />
      <em>Before it got loud.</em>
    </h2>

    <p class="cta__sub reveal">
      Free to install. Runs on your API key.
      No subscription, no account, no tracking.
    </p>

    <div class="cta__actions reveal">
      <a
        href="https://chrome.google.com/webstore"
        class="btn btn-primary cta__btn"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Install Devoke from the Chrome Web Store"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
          <circle cx="12" cy="12" r="4" fill="currentColor"/>
        </svg>
        Install Devoke for Chrome
      </a>
    </div>

    <p class="cta__footnote reveal">
      Requires an <a href="https://platform.claude.com" target="_blank" rel="noopener noreferrer">Anthropic API key</a> ·
      Chrome / Chromium only · v0.6
    </p>
  </div>
</section>

<footer class="site-footer">
  <div class="container site-footer__inner">
    <span class="site-footer__brand">◎ Devoke</span>
    <nav class="site-footer__nav" aria-label="Footer navigation">
      <a href="/privacy">Privacy policy</a>
    </nav>
    <span class="site-footer__copy">
      Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
    </span>
  </div>
</footer>

<style>
  .cta {
    background: var(--color-surface);
    clip-path: var(--clip-up);
    margin-top: -2px;
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .cta__mark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display);
    font-size: clamp(20rem, 45vw, 50rem);
    line-height: 1;
    color: var(--color-green);
    opacity: 0.03;
    user-select: none;
    pointer-events: none;
    white-space: nowrap;
  }

  .cta__inner {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .cta__heading {
    font-size: clamp(2.5rem, 6vw, 5rem);
    color: var(--color-text);
    max-width: 16ch;
    margin-inline: auto;
  }

  .cta__heading em {
    font-style: italic;
    color: var(--color-green);
  }

  .cta__sub {
    font-size: 1rem;
    color: var(--color-muted);
    text-align: center;
    max-width: 44ch;
  }

  .cta__actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta__btn {
    font-size: 1rem;
    padding: 1rem 2.2rem;
  }

  .cta__footnote {
    font-size: 0.78rem;
    color: var(--color-muted);
    text-align: center;
    max-width: 100%;
    opacity: 0.7;
  }

  .cta__footnote a {
    color: var(--color-muted);
    text-decoration: underline;
    text-decoration-color: rgba(138, 160, 144, 0.4);
  }

  /* Footer */
  .site-footer {
    background: var(--color-bg);
    padding-block: 2rem;
    border-top: 1px solid rgba(122, 184, 138, 0.08);
  }

  .site-footer__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .site-footer__brand {
    font-family: var(--font-display);
    font-size: 1.1rem;
    color: var(--color-green);
    letter-spacing: 0.02em;
  }

  .site-footer__nav {
    display: flex;
    gap: 1.5rem;
  }

  .site-footer__nav a {
    font-family: var(--font-ui);
    font-size: 0.8rem;
    color: var(--color-muted);
    letter-spacing: 0.04em;
  }

  .site-footer__nav a:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .site-footer__copy {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--color-muted);
    opacity: 0.5;
  }

  .site-footer__copy a {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: rgba(138, 160, 144, 0.3);
  }
</style>
