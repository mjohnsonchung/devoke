---
export const prerender = true;
import Base from '../layouts/Base.astro';
---

<Base
  title="Dashboard"
  description="Your Devoke account — usage, plan, and billing."
  canonical="https://devoke.app/dashboard"
>
  <main class="dash-wrap">
    <header class="dash-header">
      <a href="/" class="dash-brand">◎ Devoke</a>
      <button class="btn btn-ghost dash-signout" id="signout-btn">Sign out</button>
    </header>

    <!-- Loading state -->
    <div class="dash-loading" id="dash-loading">
      <span class="dash-spinner" aria-label="Loading…">◎</span>
    </div>

    <!-- Unauthenticated state -->
    <div class="dash-unauth" id="dash-unauth" hidden>
      <p>You're not signed in.</p>
      <a href="/login" class="btn btn-primary">Sign in</a>
    </div>

    <!-- Dashboard content -->
    <div class="dash-content" id="dash-content" hidden>
      <div class="container dash-inner">
        <!-- Account -->
        <section class="dash-section" aria-labelledby="account-heading">
          <h1 id="account-heading" class="dash-heading">Your account</h1>
          <div class="dash-meta">
            <span class="dash-email" id="dash-email"></span>
            <span class="dash-plan-badge" id="dash-plan-badge"></span>
          </div>
        </section>

        <!-- Usage -->
        <section class="dash-section" aria-labelledby="usage-heading">
          <h2 id="usage-heading" class="dash-subheading">This month</h2>
          <div class="dash-usage-row">
            <span class="dash-usage-label" id="usage-label">— / — rewrites</span>
            <span class="dash-usage-period" id="usage-period"></span>
          </div>
          <div class="dash-bar-wrap" role="progressbar" id="usage-bar-wrap">
            <div class="dash-bar-fill" id="usage-bar-fill"></div>
          </div>
        </section>

        <!-- Billing -->
        <section class="dash-section" aria-labelledby="billing-heading">
          <h2 id="billing-heading" class="dash-subheading">Billing</h2>
          <p class="dash-billing-note" id="billing-note"></p>
          <button class="btn btn-ghost" id="portal-btn">
            Manage billing →
          </button>
        </section>
      </div>
    </div>
  </main>
</Base>

<script>
  const SUPABASE_URL      = import.meta.env.PUBLIC_SUPABASE_URL;
  const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

  const loadingEl = document.getElementById('dash-loading')!;
  const unauthEl  = document.getElementById('dash-unauth')!;
  const contentEl = document.getElementById('dash-content')!;

  async function getSession() {
    const raw = localStorage.getItem('devoke_session');
    if (!raw) return null;

    let session = JSON.parse(raw);

    // Refresh token if expired (with 60s buffer)
    if (Date.now() > session.expires_at - 60_000) {
      const res = await fetch(`${SUPABASE_URL}/auth/v1/token?grant_type=refresh_token`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'apikey': SUPABASE_ANON_KEY },
        body:    JSON.stringify({ refresh_token: session.refresh_token }),
      });
      if (!res.ok) { localStorage.removeItem('devoke_session'); return null; }
      const data = await res.json();
      session = {
        access_token:  data.access_token,
        refresh_token: data.refresh_token,
        expires_at:    Date.now() + data.expires_in * 1000,
        email:         session.email,
      };
      localStorage.setItem('devoke_session', JSON.stringify(session));
    }

    return session;
  }

  async function init() {
    const session = await getSession();

    loadingEl.hidden = true;

    if (!session) {
      unauthEl.hidden = false;
      return;
    }

    contentEl.hidden = false;

    // Populate email
    (document.getElementById('dash-email') as HTMLElement).textContent = session.email;

    // Fetch usage
    const usageRes = await fetch('/api/usage', {
      headers: { Authorization: `Bearer ${session.access_token}` },
    });

    if (usageRes.status === 401) {
      localStorage.removeItem('devoke_session');
      window.location.href = '/login';
      return;
    }

    const usage = await usageRes.json();

    // Plan badge
    const badge = document.getElementById('dash-plan-badge')!;
    const statusMap: Record<string, string> = {
      trialing: 'Trial',
      active:   'Active',
      past_due: 'Past due',
      canceled: 'Canceled',
      none:     'No plan',
    };
    badge.textContent = `${usage.tier ? usage.tier.charAt(0).toUpperCase() + usage.tier.slice(1) : ''} · ${statusMap[usage.status] ?? usage.status}`;
    badge.className   = `dash-plan-badge dash-plan-badge--${usage.status}`;

    // Usage bar
    const used  = usage.used  ?? 0;
    const limit = usage.limit ?? 500;
    const pct   = Math.min((used / limit) * 100, 100);

    (document.getElementById('usage-label') as HTMLElement).textContent = `${used} / ${limit} rewrites`;
    (document.getElementById('usage-bar-fill') as HTMLElement).style.width = `${pct}%`;
    (document.getElementById('usage-bar-fill') as HTMLElement).className =
      `dash-bar-fill${pct >= 90 ? ' dash-bar-fill--warn' : ''}`;

    // Period
    if (usage.periodEnd) {
      const end = new Date(usage.periodEnd).toLocaleDateString('en-GB', { day: 'numeric', month: 'long' });
      (document.getElementById('usage-period') as HTMLElement).textContent = `Resets ${end}`;
    }

    // Billing note
    const noteEl = document.getElementById('billing-note')!;
    if (usage.status === 'trialing' && usage.trialEnd) {
      const end = new Date(usage.trialEnd).toLocaleDateString('en-GB', { day: 'numeric', month: 'long' });
      noteEl.textContent = `Your free trial ends ${end}. No charge until then.`;
    } else if (usage.periodEnd) {
      const end = new Date(usage.periodEnd).toLocaleDateString('en-GB', { day: 'numeric', month: 'long' });
      noteEl.textContent = `Next billing date: ${end}.`;
    }

    // Billing portal
    document.getElementById('portal-btn')!.addEventListener('click', async () => {
      const res = await fetch('/api/stripe/portal', {
        method:  'POST',
        headers: { Authorization: `Bearer ${session.access_token}` },
      });
      const data = await res.json();
      if (data.url) window.location.href = data.url;
    });
  }

  // Sign out
  document.getElementById('signout-btn')!.addEventListener('click', () => {
    localStorage.removeItem('devoke_session');
    window.location.href = '/';
  });

  init();
</script>

<style>
  .dash-wrap {
    min-height: 100svh;
    background: var(--color-bg);
    display: flex;
    flex-direction: column;
  }

  .dash-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgba(122, 184, 138, 0.08);
  }

  .dash-brand {
    font-family: var(--font-display);
    font-size: 1.2rem;
    color: var(--color-green);
    text-decoration: none;
    opacity: 0.8;
  }

  .dash-signout {
    font-size: 0.8rem;
    padding: 0.5rem 1rem;
    cursor: pointer;
  }

  .dash-loading {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .dash-spinner {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--color-green);
    opacity: 0.3;
    animation: spin 2s linear infinite;
  }

  @keyframes spin { to { transform: rotate(360deg); } }

  .dash-unauth {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.5rem;
    color: var(--color-muted);
    font-family: var(--font-ui);
  }

  .dash-content { flex: 1; }

  .dash-inner {
    padding-block: clamp(2.5rem, 6vw, 5rem);
    display: flex;
    flex-direction: column;
    gap: 3rem;
    max-width: 600px;
  }

  .dash-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .dash-subheading {
    font-size: 1.4rem;
    color: var(--color-text);
    margin-bottom: 0.8rem;
  }

  .dash-meta {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .dash-email {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: var(--color-muted);
  }

  .dash-plan-badge {
    font-family: var(--font-ui);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.55rem;
    border-radius: 2px;
    border: 1px solid rgba(122, 184, 138, 0.3);
    color: var(--color-green);
  }

  .dash-plan-badge--past_due { color: var(--color-red); border-color: rgba(196,117,106,0.3); }
  .dash-plan-badge--canceled { color: var(--color-muted); border-color: rgba(138,160,144,0.2); }

  .dash-usage-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 0.7rem;
  }

  .dash-usage-label {
    font-family: var(--font-ui);
    font-size: 1rem;
    color: var(--color-text);
  }

  .dash-usage-period {
    font-family: var(--font-ui);
    font-size: 0.78rem;
    color: var(--color-muted);
    font-style: italic;
  }

  .dash-bar-wrap {
    width: 100%;
    height: 6px;
    background: rgba(122, 184, 138, 0.12);
    border-radius: 99px;
    overflow: hidden;
  }

  .dash-bar-fill {
    height: 100%;
    background: var(--color-green);
    border-radius: 99px;
    transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .dash-bar-fill--warn { background: var(--color-red); }

  .dash-billing-note {
    font-family: var(--font-ui);
    font-size: 0.88rem;
    color: var(--color-muted);
    max-width: 100%;
    margin-bottom: 1rem;
  }
</style>
